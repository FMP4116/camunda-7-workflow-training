<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://example.com/bpmn">

  <bpmn:process id="proceso_ejemplo" name="Proceso de ejemplo" isExecutable="true">

    <bpmn:startEvent id="inicio" name="Inicio del proceso">
      <bpmn:outgoing>flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:task id="tarea_revision" name="Revisar solicitud">
      <bpmn:incoming>flow_1</bpmn:incoming>
      <bpmn:outgoing>flow_2</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="tarea_aprobacion" name="Aprobar solicitud">
      <bpmn:incoming>flow_2</bpmn:incoming>
      <bpmn:outgoing>flow_3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="fin" name="Fin del proceso">
      <bpmn:incoming>flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="flow_1" sourceRef="inicio" targetRef="tarea_revision"/>
    <bpmn:sequenceFlow id="flow_2" sourceRef="tarea_revision" targetRef="tarea_aprobacion"/>
    <bpmn:sequenceFlow id="flow_3" sourceRef="tarea_aprobacion" targetRef="fin"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="proceso_ejemplo">

      <bpmndi:BPMNShape id="shape_start" bpmnElement="inicio">
        <dc:Bounds x="150" y="120" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_task1" bpmnElement="tarea_revision">
        <dc:Bounds x="250" y="100" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_task2" bpmnElement="tarea_aprobacion">
        <dc:Bounds x="420" y="100" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_end" bpmnElement="fin">
        <dc:Bounds x="600" y="120" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_flow1" bpmnElement="flow_1">
        <di:waypoint x="186" y="138"/>
        <di:waypoint x="250" y="138"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow2" bpmnElement="flow_2">
        <di:waypoint x="370" y="138"/>
        <di:waypoint x="420" y="138"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow3" bpmnElement="flow_3">
        <di:waypoint x="540" y="138"/>
        <di:waypoint x="600" y="138"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>